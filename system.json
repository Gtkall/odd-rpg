{
  "id": "odd-rpg",
  "title": "ODD RPG",
  "description": "The ODD RPG game system for Foundry Virtual Tabletop.",
  "version": "0.2.0",
  "compatibility": {
    "minimum": 13,
    "verified": 13
  },
  "authors": [
    {
      "name": "George Karettas",
      "url": "https://github.com/Gtkall"
    }
  ],
  "esmodules": [
    "odd-rpg.js"
  ],
  "styles": [
    "styles/odd-rpg.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "biography"
        ]
      }
    },
    "Item": {
      "item": {
        "htmlFields": [
          "description"
        ]
      },
      "feature": {
        "htmlFields": [
          "description"
        ]
      },
      "spell": {
        "htmlFields": [
          "description"
        ]
      },
      "weapon": {
        "htmlFields": [
          "description"
        ]
      },
      "armor": {
        "htmlFields": [
          "description"
        ]
      }
    }
  },
  "socket": false,
  "initiative": "1d20",
  "grid": {
    "distance": 5,
    "units": "ft"
  },
  "primaryTokenAttribute": "xp",
  "secondaryTokenAttribute": "statistics.magicPoints",
  "url": "https://github.com/Gtkall/odd-rpg",
  "manifest": "https://github.com/Gtkall/odd-rpg/releases/latest/download/system.json",
  "download": "https://github.com/Gtkall/odd-rpg/releases/download/v0.2.0/odd-rpg.zip"
}
