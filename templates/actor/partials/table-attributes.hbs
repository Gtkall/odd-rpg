{{!-- Attributes table --}}
<div class="attributes-panel">
  <h3 class="panel-header">{{localize "ODD.Sections.attributes"}}</h3>
  <div class="attributes-grid">
    {{#each attributeLayout}}
    <div class="attribute-pair">
      <label class="attr-label rollable" data-roll-attribute="{{left}}">
        {{localize (lookup ../attributeConfig left)}}
      </label>
      {{#if ../isEditMode}}
        <select name="system.attributes.{{left}}" class="attr-select">
          {{selectOptions ../attributeDiceTypes selected=(lookup ../system.attributes left) localize=true}}
        </select>
      {{else}}
        <span class="die-value-static">{{lookup ../system.attributes left}}</span>
      {{/if}}
      <label class="attr-label rollable" data-roll-attribute="{{right}}">
        {{localize (lookup ../attributeConfig right)}}
      </label>
      {{#if ../isEditMode}}
        <select name="system.attributes.{{right}}" class="attr-select">
          {{selectOptions ../attributeDiceTypes selected=(lookup ../system.attributes right) localize=true}}
        </select>
      {{else}}
        <span class="die-value-static">{{lookup ../system.attributes right}}</span>
      {{/if}}
    </div>
    {{/each}}
  </div>
</div>
