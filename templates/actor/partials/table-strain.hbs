{{!-- Strain tracker --}}
<div class="strain-panel">
  <div class="strain-header">
    <h3 class="panel-header">{{localize "ODD.Sections.strain"}}</h3>
    {{> "systems/odd-rpg/templates/actor/partials/roll-entry.hbs" staminaRoll inline=true}}
    <label class="fort-override-toggle" title="{{localize "ODD.Strain.fortitudeOverrideHint"}}">
      <input type="checkbox" name="system.strain.fortitudeManualOverride" {{#if strainFortitudeManualOverride}}checked{{/if}}>
      <span>{{localize "ODD.Strain.fortitudeManualOverride"}}</span>
    </label>
  </div>

  <div class="strain-row">
    {{#each strainSlots}}
    <div class="strain-slot {{#if isLocked}}is-locked{{/if}} {{#if isFortSlot}}is-fort{{/if}}">
      {{#if isLocked}}
        {{!-- Hidden input keeps the array index in the form submission --}}
        <input type="hidden" name="system.strain.slots.{{index}}" value="">
        <div class="slot-locked"></div>
      {{else}}
        <select name="system.strain.slots.{{index}}" class="slot-select">
          {{selectOptions ../strainValues selected=value localize=true}}
        </select>
      {{/if}}
      <div class="slot-label">
        {{label}}{{#if isFortSlot}}{{#if ../strainFortitudeManualOverride}}<button type="button" class="fort-lock-btn" data-fort-slot-toggle="{{index}}" title="{{#if isLocked}}Unlock slot{{else}}Lock slot{{/if}}">{{#if isLocked}}🔒︎{{else}}🔓︎{{/if}}</button>{{/if}}{{/if}}
      </div>
    </div>
    {{/each}}
  </div>

  {{!-- Penalty row: mirrors the slot flex layout so dice align with their columns --}}
  <div class="strain-penalty-row">
    <span class="strain-penalty-label">{{localize "ODD.Strain.fatiguePenalty"}}</span>
    {{#each strainSlots}}
    <div class="penalty-cell">{{#if fatiguePenalty}}{{fatiguePenalty}}{{/if}}</div>
    {{/each}}
  </div>
</div>
