{{!-- Reusable roll entry partial.
     Context: { key, label, formula, sourceLabels, modifier, inline? }
     inline=true: compact single-row layout (for embedding in headers/rows) --}}
<div class="roll-entry{{#if inline}} roll-entry--inline{{/if}}">
  <div class="roll-name">{{localize label}}</div>
  <div class="roll-sources">{{sourceLabels}}</div>
  <div class="roll-formula-row">
    {{#if formula}}
    <div class="roll-formula">{{formula}}</div>
    {{/if}}
    <label class="bonus-toggle" title="Add bonus formula">
      <input type="checkbox" {{#if modifier}}checked{{/if}}>
      <span class="bonus-indicator">+</span>
    </label>
    <div class="roll-modifier-field">
      <input type="text" name="system.rollModifiers.{{key}}" value="{{modifier}}" placeholder="+1d4">
    </div>
  </div>
  <div class="roll-actions">
    <button type="button" class="roll-action-roll" data-common-roll="{{key}}"><span class="roll-emoji">🎲</span> Roll</button>
    <button type="button" class="roll-action-pool" data-common-roll="{{key}}">Add to pool</button>
  </div>
</div>
