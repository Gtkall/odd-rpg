{{!-- Skills table --}}
<div class="skills-panel">
  <h3 class="panel-header">{{localize "ODD.Sections.skills"}}</h3>
  {{#each skillLayout}}
  <div class="skill-row-group">
    {{#each this}}
    <div class="skill-category">
      <div class="category-header">{{localize label}}</div>
      {{#each skills}}
      <div class="skill-row">
        <span class="skill-name rollable"
              data-roll-skill="{{key}}"
              data-roll-category="{{category}}">{{localize label}}</span>
        {{#if ../../../isEditMode}}
          <select name="system.skills.{{category}}.{{key}}" class="skill-select">
            {{selectOptions ../../../diceTypes
              selected=(lookup (lookup ../../../system.skills category) key)
              localize=true}}
          </select>
        {{else}}
          <span class="die-value-static">
            {{#if (lookup (lookup ../../../system.skills category) key)}}
              {{lookup (lookup ../../../system.skills category) key}}
            {{else}}—{{/if}}
          </span>
        {{/if}}
      </div>
      {{/each}}
      {{#each customSkills}}
      <div class="skill-row custom-skill-row">
        <span class="skill-name rollable custom-skill-name"
              data-roll-custom-skill="{{id}}">{{name}}</span>
        <span class="custom-badge">(custom)</span>
        {{#if ../../../isEditMode}}
          <select class="skill-select custom-skill-die" data-custom-skill-id="{{id}}">
            {{selectOptions ../../../diceTypes selected=die localize=true}}
          </select>
          <span class="custom-skill-delete-confirm">
            <span class="delete-confirm-label">Delete?</span>
            <button type="button" class="custom-skill-confirm-delete danger-btn" data-custom-skill-id="{{id}}">Delete</button>
            <button type="button" class="custom-skill-cancel-delete icon-btn">Cancel</button>
          </span>
          <button type="button" class="custom-skill-delete danger-btn" data-custom-skill-id="{{id}}" title="Remove">×</button>
        {{else}}
          <span class="die-value-static">{{#if die}}{{die}}{{else}}—{{/if}}</span>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{/each}}
  </div>
  {{/each}}

  {{#if isEditMode}}
  <div class="custom-skill-add-section">
    <div class="custom-skill-form hidden">
      <input type="text" class="custom-skill-name-input" placeholder="Skill name…" maxlength="40">
      <select class="custom-skill-category-select">
        {{#each customSkillCategories}}
        <option value="{{key}}">{{localize label}}</option>
        {{/each}}
      </select>
      <span class="custom-skill-form-spacer"></span>
      <button type="button" class="custom-skill-save-btn">Save</button>
      <button type="button" class="custom-skill-cancel-btn">Cancel</button>
    </div>
    <button type="button" class="add-custom-skill-btn">+ Add custom skill</button>
  </div>
  {{/if}}
</div>
