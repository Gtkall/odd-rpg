{{!-- Talents & Flaws Tab --}}
<section class="tab character-talents-flaws {{ tab.cssClass }}" data-group="{{ tab.group }}" data-tab="{{ tab.id }}">

  {{!-- Talents --}}
  <div class="tf-section talents-section">
    <div class="tf-section-header">
      <h3 class="panel-header">{{localize "ODD.Talent.sectionTitle"}}</h3>
      {{#if isEditMode}}
      <input type="text" class="inventory-add-input" data-item-type="talent"
        placeholder="{{localize 'ODD.Talent.addTalent'}}" />
      {{/if}}
    </div>

    <div class="tf-filter-row">
      <input type="text" class="tf-talent-search" placeholder="{{localize 'ODD.Filter.searchName'}}" />
      <select class="tf-talent-category">
        <option value="">{{localize "ODD.Filter.allCategories"}}</option>
        {{#each talentCategoryOptions}}
          <option value="{{this.value}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>

    {{#if talentGroups.length}}
      {{#each talentGroups}}
        <div class="talent-group">
          <div class="talent-group-header">{{this.treeName}}</div>
          {{#each this.items}}
            <div class="item talent-entry" data-item-id="{{this.id}}"
              data-name="{{this.name}}" data-category="{{this.category}}">
              <div class="talent-entry-summary">
                <button type="button" class="tf-expand-toggle" data-target="talent-detail-{{this.id}}" title="Details">▼</button>
                <span class="talent-entry-name">{{this.name}}</span>
                <div class="talent-entry-meta">
                  <span class="flaw-category">{{this.categoryLabel}}</span>
                  {{#unless this.isSide}}
                    <span class="talent-badge talent-rank">{{this.rank}}</span>
                  {{/unless}}
                  <span class="talent-badge talent-type talent-type-{{this.talentType}}">
                    {{this.talentTypeLabel}}
                  </span>
                </div>
                <span class="flaw-xp">{{this.xpCost}} XP</span>
                {{#if ../../isEditMode}}
                <div class="item-controls">
                  <button type="button" class="item-edit" data-item-id="{{this.id}}" title="Edit">✎</button>
                  <button type="button" class="item-delete" data-item-id="{{this.id}}" title="Delete">✕</button>
                </div>
                {{/if}}
              </div>
              <div class="tf-entry-detail open" id="talent-detail-{{this.id}}">
                {{#if this.prerequisites}}
                  <div class="tf-detail-row tf-prerequisites">
                    <span class="tf-detail-label">{{localize "ODD.Talent.prerequisites"}}</span>
                    <span class="tf-detail-value">{{this.prerequisites}}</span>
                  </div>
                {{/if}}
                {{#if this.enrichedDescription}}
                  <div class="tf-detail-description">{{{this.enrichedDescription}}}</div>
                {{/if}}
                {{#each this.enrichedEffects}}
                  <div class="tf-effect-block">
                    {{#if this.title}}<div class="tf-effect-title">{{this.title}}</div>{{/if}}
                    <div class="tf-effect-body">{{{this.body}}}</div>
                  </div>
                {{/each}}
              </div>
            </div>
          {{/each}}
        </div>
      {{/each}}
    {{/if}}
  </div>

  {{!-- Flaws --}}
  <div class="tf-section flaws-section">
    <div class="tf-section-header">
      <h3 class="panel-header">{{localize "ODD.Flaw.sectionTitle"}}</h3>
      {{#if isEditMode}}
      <input type="text" class="inventory-add-input" data-item-type="flaw"
        placeholder="{{localize 'ODD.Flaw.addFlaw'}}" />
      {{/if}}
    </div>

    <div class="tf-filter-row">
      <input type="text" class="tf-flaw-search" placeholder="{{localize 'ODD.Filter.searchName'}}" />
      <select class="tf-flaw-category">
        <option value="">{{localize "ODD.Filter.allCategories"}}</option>
        {{#each flawCategoryOptions}}
          <option value="{{this.value}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>

    {{#if flawRows.length}}
      <div class="flaw-list">
        {{#each flawRows}}
          <div class="item flaw-entry" data-item-id="{{this.id}}"
            data-name="{{this.name}}" data-category="{{this.category}}">
            <div class="flaw-entry-summary">
              <button type="button" class="tf-expand-toggle" data-target="flaw-detail-{{this.id}}" title="Details">▶</button>
              <span class="flaw-symbol" title="{{this.severity}}">{{this.symbol}}</span>
              <span class="flaw-entry-name">{{this.name}}</span>
              <span class="flaw-category">{{this.categoryLabel}}</span>
              <span class="flaw-xp">{{this.xpValue}} XP</span>
              {{#if ../isEditMode}}
              <div class="item-controls">
                <button type="button" class="item-edit" data-item-id="{{this.id}}" title="Edit">✎</button>
                <button type="button" class="item-delete" data-item-id="{{this.id}}" title="Delete">✕</button>
              </div>
              {{/if}}
            </div>
            {{#if this.enrichedDescription}}
              <div class="tf-entry-detail open" id="flaw-detail-{{this.id}}">
                <div class="tf-detail-description">{{{this.enrichedDescription}}}</div>
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}
  </div>

</section>
