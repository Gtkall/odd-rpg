<div class="odd-rpg weapon-form">

  {{!-- Header --}}
  <header class="weapon-header">
    <img class="item-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="48" height="48" />
    <input class="item-name" name="name" type="text" value="{{item.name}}" placeholder="Weapon Name" />
  </header>

  {{!-- Weapon type + Hands toggles on same row --}}
  <div class="weapon-toggles">
    <div class="toggle-group">
      {{#each weaponTypes}}
        <label class="toggle-btn{{#if (eq ../system.weaponType @key)}} active{{/if}}">
          <input type="radio" name="system.weaponType" value="{{@key}}"
            {{#if (eq ../system.weaponType @key)}}checked{{/if}}>
          {{localize this}}
        </label>
      {{/each}}
    </div>
    <div class="toggle-group">
      {{#each weaponHands}}
        <label class="toggle-btn{{#if (eq ../system.hands @key)}} active{{/if}}">
          <input type="radio" name="system.hands" value="{{@key}}"
            {{#if (eq ../system.hands @key)}}checked{{/if}}>
          {{localize this}}
        </label>
      {{/each}}
    </div>
  </div>

  {{!-- Versatile: two side-by-side sections each with their own labels --}}
  {{#if showBoth}}
    <div class="hand-configs hand-configs-split">

      {{!-- 1H section --}}
      <div class="hand-section">
        <div class="hand-section-header">{{localize "ODD.Weapon.Hands.oneHanded"}}</div>
        <div class="config-row">
          <div class="config-row-label">{{localize "ODD.Weapon.Tempos"}}</div>
          <div class="config-cell">
            <input type="number" name="system.oneHanded.tempos"
              value="{{system.oneHanded.tempos}}" min="1" max="10" />
          </div>
        </div>
        <div class="config-row">
          <div class="config-row-label">{{localize distanceLabel}}</div>
          <div class="config-cell">
            <select name="system.oneHanded.distance">
              {{selectOptions weaponDistance selected=system.oneHanded.distance localize=true}}
            </select>
          </div>
        </div>
        <div class="config-row">
          <div class="config-row-label">{{localize "ODD.Weapon.Accuracy"}}</div>
          <div class="config-cell">
            <select name="system.oneHanded.accuracy">
              {{selectOptions diceTypes selected=system.oneHanded.accuracy localize=true}}
            </select>
          </div>
        </div>
        <div class="config-row">
          <div class="config-row-label">{{localize "ODD.Weapon.Damage"}}</div>
          <div class="config-cell damage-cell">
            <label class="bonus-toggle" title="{{localize "ODD.Weapon.DamageBonus"}}">
              <input type="checkbox" name="system.oneHanded.damage.isBonus"
                {{#if system.oneHanded.damage.isBonus}}checked{{/if}}>
              <span class="bonus-indicator">+</span>
            </label>
            <input type="number" name="system.oneHanded.damage.diceCount"
              value="{{system.oneHanded.damage.diceCount}}" min="0" />
            <select name="system.oneHanded.damage.dieType">
              {{selectOptions diceTypes selected=system.oneHanded.damage.dieType localize=true}}
            </select>
          </div>
        </div>
      </div>

      {{!-- 2H section --}}
      <div class="hand-section">
        <div class="hand-section-header">{{localize "ODD.Weapon.Hands.twoHanded"}}</div>
        <div class="config-row">
          <div class="config-row-label">{{localize "ODD.Weapon.Tempos"}}</div>
          <div class="config-cell">
            <input type="number" name="system.twoHanded.tempos"
              value="{{system.twoHanded.tempos}}" min="1" max="10" />
          </div>
        </div>
        <div class="config-row">
          <div class="config-row-label">{{localize distanceLabel}}</div>
          <div class="config-cell">
            <select name="system.twoHanded.distance">
              {{selectOptions weaponDistance selected=system.twoHanded.distance localize=true}}
            </select>
          </div>
        </div>
        <div class="config-row">
          <div class="config-row-label">{{localize "ODD.Weapon.Accuracy"}}</div>
          <div class="config-cell">
            <select name="system.twoHanded.accuracy">
              {{selectOptions diceTypes selected=system.twoHanded.accuracy localize=true}}
            </select>
          </div>
        </div>
        <div class="config-row">
          <div class="config-row-label">{{localize "ODD.Weapon.Damage"}}</div>
          <div class="config-cell damage-cell">
            <label class="bonus-toggle" title="{{localize "ODD.Weapon.DamageBonus"}}">
              <input type="checkbox" name="system.twoHanded.damage.isBonus"
                {{#if system.twoHanded.damage.isBonus}}checked{{/if}}>
              <span class="bonus-indicator">+</span>
            </label>
            <input type="number" name="system.twoHanded.damage.diceCount"
              value="{{system.twoHanded.damage.diceCount}}" min="0" />
            <select name="system.twoHanded.damage.dieType">
              {{selectOptions diceTypes selected=system.twoHanded.damage.dieType localize=true}}
            </select>
          </div>
        </div>
      </div>

    </div>

  {{!-- 1H or 2H only: single column with labels on left --}}
  {{else}}
    <div class="hand-configs">
      <div class="config-row">
        <div class="config-row-label">{{localize "ODD.Weapon.Tempos"}}</div>
        {{#if showOneHanded}}
          <div class="config-cell">
            <input type="number" name="system.oneHanded.tempos"
              value="{{system.oneHanded.tempos}}" min="1" max="10" />
          </div>
        {{/if}}
        {{#if showTwoHanded}}
          <div class="config-cell">
            <input type="number" name="system.twoHanded.tempos"
              value="{{system.twoHanded.tempos}}" min="1" max="10" />
          </div>
        {{/if}}
      </div>
      <div class="config-row">
        <div class="config-row-label">{{localize distanceLabel}}</div>
        {{#if showOneHanded}}
          <div class="config-cell">
            <select name="system.oneHanded.distance">
              {{selectOptions weaponDistance selected=system.oneHanded.distance localize=true}}
            </select>
          </div>
        {{/if}}
        {{#if showTwoHanded}}
          <div class="config-cell">
            <select name="system.twoHanded.distance">
              {{selectOptions weaponDistance selected=system.twoHanded.distance localize=true}}
            </select>
          </div>
        {{/if}}
      </div>
      <div class="config-row">
        <div class="config-row-label">{{localize "ODD.Weapon.Accuracy"}}</div>
        {{#if showOneHanded}}
          <div class="config-cell">
            <select name="system.oneHanded.accuracy">
              {{selectOptions diceTypes selected=system.oneHanded.accuracy localize=true}}
            </select>
          </div>
        {{/if}}
        {{#if showTwoHanded}}
          <div class="config-cell">
            <select name="system.twoHanded.accuracy">
              {{selectOptions diceTypes selected=system.twoHanded.accuracy localize=true}}
            </select>
          </div>
        {{/if}}
      </div>
      <div class="config-row">
        <div class="config-row-label">{{localize "ODD.Weapon.Damage"}}</div>
        {{#if showOneHanded}}
          <div class="config-cell damage-cell">
            <label class="bonus-toggle" title="{{localize "ODD.Weapon.DamageBonus"}}">
              <input type="checkbox" name="system.oneHanded.damage.isBonus"
                {{#if system.oneHanded.damage.isBonus}}checked{{/if}}>
              <span class="bonus-indicator">+</span>
            </label>
            <input type="number" name="system.oneHanded.damage.diceCount"
              value="{{system.oneHanded.damage.diceCount}}" min="0" />
            <select name="system.oneHanded.damage.dieType">
              {{selectOptions diceTypes selected=system.oneHanded.damage.dieType localize=true}}
            </select>
          </div>
        {{/if}}
        {{#if showTwoHanded}}
          <div class="config-cell damage-cell">
            <label class="bonus-toggle" title="{{localize "ODD.Weapon.DamageBonus"}}">
              <input type="checkbox" name="system.twoHanded.damage.isBonus"
                {{#if system.twoHanded.damage.isBonus}}checked{{/if}}>
              <span class="bonus-indicator">+</span>
            </label>
            <input type="number" name="system.twoHanded.damage.diceCount"
              value="{{system.twoHanded.damage.diceCount}}" min="0" />
            <select name="system.twoHanded.damage.dieType">
              {{selectOptions diceTypes selected=system.twoHanded.damage.dieType localize=true}}
            </select>
          </div>
        {{/if}}
      </div>
    </div>
  {{/if}}

  {{!-- Notes / Tags --}}
  <div class="weapon-tags">
    <div class="tags-label">{{localize "ODD.Weapon.Notes"}}</div>
    <div class="tag-pills">
      {{#each system.notes}}
        <span class="tag-pill">
          {{this}}
          <button type="button" class="tag-remove" data-remove-tag="{{this}}" title="Remove">✕</button>
        </span>
      {{/each}}
    </div>
    <input class="tag-input" type="text"
      placeholder="{{localize "ODD.Weapon.TagPlaceholder"}}" />
  </div>

</div>
