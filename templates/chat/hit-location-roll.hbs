{{!-- Hit Location Roll Chat Message --}}
<div class="odd-roll-result hit-location-result">

  <div class="roll-label">{{localize "ODD.Wounds.sectionTitle"}}</div>

  <div class="hit-location-chat-layout">

    {{!-- Body diagram — hit region gets .chat-hit class --}}
    <svg class="chat-body-diagram"
         xmlns="http://www.w3.org/2000/svg"
         viewBox="0 0 100 220"
         aria-label="Hit location diagram">

      <circle  class="chat-body-region{{#if (eq locationKey 'head')}} chat-hit{{/if}}"
               cx="50" cy="16" r="12" />
      <rect    class="chat-body-neck" x="46" y="28" width="8" height="7" rx="2" />
      <path    class="chat-body-region{{#if (eq locationKey 'torso')}} chat-hit{{/if}}"
               d="M36,37 L64,37 L64,106 Q64,111 59,113 L41,113 Q36,111 36,106 Z" />
      <path    class="chat-body-region{{#if (eq locationKey 'rightArm')}} chat-hit{{/if}}"
               d="M33,40 L18,46 L10,74 L10,106 Q10,111 15,113 L20,113 Q25,111 26,106 L26,76 L32,51 Z" />
      <path    class="chat-body-region{{#if (eq locationKey 'leftArm')}} chat-hit{{/if}}"
               d="M67,40 L82,46 L90,74 L90,106 Q90,111 85,113 L80,113 Q75,111 74,106 L74,76 L68,51 Z" />
      <path    class="chat-body-region{{#if (eq locationKey 'rightLeg')}} chat-hit{{/if}}"
               d="M37,116 L47,116 L48,158 L46,198 Q46,206 42,208 L36,208 Q32,206 32,198 L33,158 Z" />
      <path    class="chat-body-region{{#if (eq locationKey 'leftLeg')}} chat-hit{{/if}}"
               d="M53,116 L63,116 L67,158 L68,198 Q68,206 64,208 L58,208 Q54,206 54,198 L52,158 Z" />

    </svg>

    {{!-- Roll result --}}
    <div class="hit-location-chat-info">
      <div class="roll-die-entry">
        <div class="die-chip">{{total}}</div>
        <div class="die-meta">
          <span class="die-type">d20</span>
        </div>
      </div>
      <div class="hit-location-chat-name">{{locationLabel}}</div>
    </div>

  </div>

</div>
